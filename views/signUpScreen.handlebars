<form action="/createUser" method="post">
            <label for="login">
                Login: 
                <input type="text" name="login" id="login" required>
            </label>

            <label for="password">
                Password:
                <input type="password" name="password" id="password" required>
            </label>

            <button type="submit">Sign Up</button>        
</form>